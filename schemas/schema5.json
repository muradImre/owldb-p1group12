{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "age": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "major": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "object",
            "properties": {
              "user": { "type": "string" },
              "user2": { "type": "string" }
            },
            "additionalProperties": true
          }
        ]
      }
    }
  },
  "required": ["age", "name", "major"]
}
