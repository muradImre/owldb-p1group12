{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "age": {
        "type": "integer",
        "minimum": 0
      },
      "name": {
        "type": "string"
      },
      "major": {
        "type": "array",
        "items": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": true
            },
            {
              "type": "integer"
            },
            {
              "type": "boolean"
            },
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        }
      },
      "courses": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "required": ["age", "name", "major", "courses"]
  }
  